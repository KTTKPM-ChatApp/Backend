# --- DATABASE ---
MYSQL_ROOT_PASSWORD=your_root_password_here
DB_PASS=your_db_password_here
DB_CONNECT_RETRY_ATTEMPTS=25
DB_CONNECT_RETRY_DELAY_MS=3000
DB_CONNECT_RETRY_MAX_DELAY_MS=30000

# --- SECURITY ---
JWT_SECRET=your_jwt_signing_secret
JWT_REFRESH_SECRET=your_jwt_refresh_secret
INTERNAL_API_KEY=your_internal_api_key_for_services

# --- MESSAGE BROKER ---
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_RECONNECT_INITIAL_DELAY_MS=1000
RABBITMQ_RECONNECT_MAX_DELAY_MS=30000

# --- REDIS ---
REDIS_RECONNECT_MAX_DELAY_MS=30000

# --- EDGE / LOAD BALANCER ---
NGINX_HTTP_PORT=4321

# --- RATE LIMITING ---
RATE_LIMIT_AUTH_MAX=100
RATE_LIMIT_AUTH_PUBLIC_MAX=20
RATE_LIMIT_API_MAX=300
RATE_LIMIT_MESSAGE_WRITE_WINDOW_MS=5000
RATE_LIMIT_MESSAGE_WRITE_MAX=3
RATE_LIMIT_UPLOAD_MAX=30
RATE_LIMIT_CHATBOT_MAX=60
GATEWAY_PROXY_TIMEOUT_MS=10000

# --- CLOUDINARY ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_FOLDER=zalo-chat

# --- AI ---
GEMINI_API_KEY=
GEMINI_MODEL=

# --- CLOUDFLARE TUNNEL ---
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here