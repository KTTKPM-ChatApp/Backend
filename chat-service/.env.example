PORT=3003
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=root
DB_NAME=chat_service

RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=chat.events
RABBITMQ_ROUTING_KEY_NEW_MESSAGE=chat.new_message

# Realtime-service integration
# URL của realtime-service (Spring Boot). Để trống nếu chưa chạy realtime-service.
REALTIME_SERVICE_URL=http://localhost:8080
# Shared secret cho inter-service communication (phải khớp với INTERNAL_API_KEY của realtime-service)
INTERNAL_API_KEY=dev-internal-key-change-me
