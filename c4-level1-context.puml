@startuml C4_Context_PingMe
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

LAYOUT_WITH_LEGEND()
skinparam linetype ortho

title System Context diagram - PingMe

Person(user, "Người dùng", "Người dùng truy cập qua trình duyệt web")

System_Boundary(pingme, "PingMe System") {
  System(webapp, "Web App", "Next.js 16 + React 19, giao diện chat real-time")
  System(gateway, "API Gateway", "Express + Apollo GraphQL, cổng kết nối duy nhất")
  System(auth, "Auth Service", "Xác thực, quản lý người dùng & bạn bè")
  System(chat, "Chat Service", "Quản lý hội thoại, tin nhắn, polls, event-driven CQRS")
  System(realtime, "Realtime Service", "Spring Boot WebSocket, presence real-time")
}

System_Ext(cloudinary, "Cloudinary", "Lưu trữ & phân phối media (SaaS)")
System_Ext(browser, "Trình duyệt", "WebRTC peer-to-peer cho gọi video")
System_Ext(rabbitmq_ext, "RabbitMQ", "Event bus: chat.events (message.sent/deleted, user.*)")

Rel(user, webapp, "Sử dụng", "HTTPS + WebSocket")
Rel(webapp, gateway, "Gọi API", "REST/GraphQL")
Rel(webapp, realtime, "WebSocket/STOMP", "Tin nhắn real-time, presence")
Rel(webapp, cloudinary, "Upload/View media", "HTTPS")
Rel(gateway, auth, "Proxy auth/user/friend", "HTTP")
Rel(gateway, chat, "Proxy conversation/message", "HTTP")
Rel(chat, auth, "Fetch user info", "HTTP")
Rel(chat, realtime, "Callback (message, delete, system)", "HTTP")
Rel(chat, rabbitmq_ext, "Publish/subscribe chat events", "AMQP")
Rel(auth, rabbitmq_ext, "Publish user events", "AMQP")
Rel(user, browser, "WebRTC", "Peer-to-peer audio/video")

SHOW_LEGEND()
@enduml
