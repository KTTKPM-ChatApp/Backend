    ports:
      - "3001:3001"

  chat-service:
    build:
      context: ./chat-service
      dockerfile: Dockerfile
    container_name: ktpm-chat-service
    restart: unless-stopped
    depends_on:
      mariadb:
        condition: service_healthy
      rabbitmq:
        condition: service_healthy
    environment:
      PORT: 3003
      NODE_ENV: development
      DB_HOST: mariadb
      DB_PORT: 3306
      DB_USER: root
      DB_PASS: ${DB_PASS}
      DB_NAME: chat_service
      DB_CONNECT_RETRY_ATTEMPTS: 25
      DB_CONNECT_RETRY_DELAY_MS: 3000
      RABBITMQ_URL: amqp://${RABBITMQ_DEFAULT_USER:-guest}:${RABBITMQ_DEFAULT_PASS:-guest}@rabbitmq:5672
      RABBITMQ_EXCHANGE: chat.events
      RABBITMQ_ROUTING_KEY_NEW_MESSAGE: chat.new_message
      AUTH_SERVICE_URL: http://auth-service:3001
      # Kết nối tới realtime-service để push notification
      REALTIME_SERVICE_URL: http://realtime-service:8080
      INTERNAL_API_KEY: ktpm-internal-secret-key-2024
      # Redis
      REDIS_HOST: redis
      REDIS_PORT: "6379"
      REDIS_PASSWORD: ""
    ports:
      - "3003:3003"

  realtime-service:
    build:
