// 3. Quản lý Lời mời nhóm

// 3.1 Gửi lời mời
router.post('/:conversationId/invites',
  authenticate,
  [
    param('conversationId').isUUID(),
    body('userIds').isArray({ min: 1, max: 50 }),
    body('userIds.*').isUUID(),
    body('message').optional().isString().isLength({ max: 500 }),
